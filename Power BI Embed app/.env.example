# ─────────────────────────────────────────────
# Azure App Registration (Service Principal)
# ─────────────────────────────────────────────
TENANT_ID=your-tenant-id-here
CLIENT_ID=your-client-id-here
CLIENT_SECRET=your-client-secret-here

# ─────────────────────────────────────────────
# Entra ID User Authentication
# ─────────────────────────────────────────────
# Must match a Redirect URI added in your app registration
REDIRECT_URI=http://localhost:3000/auth/callback

# Generate a long random string — used to sign session cookies
# e.g. run: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=replace-with-a-long-random-string

# ─────────────────────────────────────────────
# Server
# ─────────────────────────────────────────────
PORT=3000

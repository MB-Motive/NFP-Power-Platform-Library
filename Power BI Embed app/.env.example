# ── Microsoft Entra ID ────────────────────────────────────────
# Your Azure AD tenant ID (found in Entra ID > Overview)
TENANT_ID=your-tenant-id-here

# App registration client ID (found in Entra ID > App registrations > your app > Overview)
CLIENT_ID=your-client-id-here

# The email address of the initial admin user. This account will be granted admin
# access automatically on login. Required — without this no one can administer the portal.
ADMIN_EMAIL=admin@yourorganisation.com

# App registration client secret (Entra ID > App registrations > your app > Certificates & secrets)
CLIENT_SECRET=your-client-secret-here

# OAuth callback URL — must match exactly what is registered in the app registration
# Local development: http://localhost:3000/auth/callback
# Production: https://your-domain.com/auth/callback
REDIRECT_URI=http://localhost:3000/auth/callback

# ── Session ───────────────────────────────────────────────────
# Random secret used to sign session cookies — generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=change-this-to-a-random-secret

# ── Server ────────────────────────────────────────────────────
PORT=3000

# Set to 'production' to enable secure cookies (HTTPS required) and combined logging
# NODE_ENV=production

# ── Application Insights (optional) ──────────────────────────
# Set this in Azure App Service Application Settings to enable telemetry.
# Leave blank for local development — the app runs without it.
# APPLICATIONINSIGHTS_CONNECTION_STRING=InstrumentationKey=xxx;IngestionEndpoint=https://...
